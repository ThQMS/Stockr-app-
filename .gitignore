.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/
# pubspec.lock IS committed for reproducible builds (this is an app, not a package).

# Platform folders are generated by `flutter create` (regenerated in CI and
# locally), so they are not versioned — keeps the Gradle setup matched to
# whatever Flutter SDK builds the app. Run `flutter create --platforms=android .`
# after cloning to build the APK locally.
/android/
/ios/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
macos/Pods/

*.iml
.idea/
.vscode/

# Android signing / secrets — must never be committed
*.jks
*.keystore
key.properties
android/key.properties
**/*.env
.env
.env.*
secrets.dart
lib/**/secrets.dart

# Generated code (produced by build_runner; regenerated in CI)
*.g.dart
*.config.dart
*.freezed.dart
*.mocks.dart

# OS noise
.DS_Store
Thumbs.db
